# ─── FastAPI ────────────────────────────────────────────────
APP_NAME=ThinkSync Models
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-at-least-32-chars-long!!

# ─── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=*

# ─── Supabase (PostgreSQL + Auth) ───────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
# Direct database connection string (Supabase pooler)
DATABASE_URL=postgresql+asyncpg://postgres:password@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:***api_key>**
# ─── Provider Interface ─────────────────────────────────────
THINKSYNC_PROVIDER=siliconflow
# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_RPM_DEFAULT=60
RATE_LIMIT_TPM_DEFAULT=100000
RATE_LIMIT_RPM_PREMIUM=300
RATE_LIMIT_TPM_PREMIUM=500000

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json